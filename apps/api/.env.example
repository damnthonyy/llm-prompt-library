# API server environment (all values have sensible defaults for local dev)

# Node environment: development | test | production
NODE_ENV=development

# Port the API listens on
PORT=4000

# Origin of the web client, allowed by CORS (credentials enabled)
WEB_ORIGIN=http://localhost:5173

# Prisma datasource (SQLite). Path is resolved relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Secret used to sign JWTs. MUST be a strong random value in production.
JWT_SECRET="dev-insecure-secret-change-me"

# JWT lifetime (e.g. 7d, 12h)
JWT_EXPIRES_IN="7d"
